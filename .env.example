# Public invite link shown on the Join button
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/your-invite

# Optional: guild ID for widget fallback (must enable Server Widget in Discord → Server Settings → Widget)
NEXT_PUBLIC_DISCORD_GUILD_ID=

# Recommended: bot token (server must have the bot; use minimal intents) + guild ID for accurate member counts
# Never expose the bot token to the client — only used in /api/discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
